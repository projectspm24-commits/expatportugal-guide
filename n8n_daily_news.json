    {
      "parameters": {
        "mode": "passThrough",
        "output": "input1"
      },
      "name": "Merge all feeds",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 2,
      "position": [
        700,
        400
      ]
    },
    {
      "parameters": {
        "functionCode": "const seen = new Set();\nconst items = [];\nconst catMap = [\n  { cat: 'bureaucracy', emoji: '\ud83c\udfdb\ufe0f', words: ['nif','aima','visa','residency','passport','citizenship','tax regime','nhr','ifici','finan\u00e7as'] },\n  { cat: 'housing',     emoji: '\ud83c\udfe0', words: ['rent','rental','housing','property','apartment','lease','mortgage'] },\n  { cat: 'lifestyle',   emoji: '\u2600\ufe0f', words: ['digital nomad','remote work','expat life','retire','retirement'] },\n  { cat: 'transport',   emoji: '\ud83d\ude87', words: ['metro','transport','flight','airport','train'] },\n  { cat: 'community',   emoji: '\ud83d\udc65', words: ['expat','community','foreigner','immigrant','integration'] },\n  { cat: 'food',        emoji: '\ud83c\udf7d\ufe0f', words: ['restaurant','food','wine','cuisine','gastronomy'] }\n];\nfunction detectCat(t) { const l=t.toLowerCase(); for(const e of catMap){if(e.words.some(w=>l.includes(w)))return e;} return {cat:'news',emoji:'\ud83d\udcf0'}; }\nfunction detectRegion(t) { const l=t.toLowerCase(); if(l.includes('lisbon')||l.includes('lisboa'))return 'Lisbon'; if(l.includes('porto'))return 'Porto'; if(l.includes('algarve')||l.includes('faro'))return 'Algarve'; if(l.includes('cascais'))return 'Cascais'; if(l.includes('braga'))return 'Braga'; if(l.includes('alentejo'))return 'Alentejo'; if(l.includes('madeira'))return 'Madeira'; return 'all'; }\nfor (const item of $input.all()) {\n  const title = (item.json.title||'').trim();\n  const key = title.toLowerCase().slice(0,60);\n  if(seen.has(key)||!title||items.length>=15) continue;\n  seen.add(key);\n  const {cat,emoji} = detectCat(title);\n  items.push({ json: { title, source_url: item.json.link||'', source_name: item.json['source.title']||'Google News', category: cat, image_emoji: emoji, region: detectRegion(title), published_at: item.json.pubDate||new Date().toISOString(), status: 'approved' } });\n}\nreturn items;"
      },
      "name": "Deduplicate and categorise",
      "type": "n8n-nodes-base.code",
      "position": [
        920,
        400
      ]
    },
    {
      "parameters": {
        "operation": "upsert",
        "tableId": "articles",
        "fieldsUi": {
          "fieldValues": [
