    {
      "parameters": {
        "functionCode": "// Mark all items from Portuguese feeds and split into batches for translation\nconst items = $input.all();\nreturn items.map(item => ({\n  json: {\n    ...item.json,\n    isPortuguese: true,\n    needsTranslation: true\n  }\n}));"
      },
      "name": "Mark as Portuguese",
      "type": "n8n-nodes-base.code",
      "position": [
        680,
        860
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "=",
              "value": "={{ (() => {\n  const ptItems = $input.all().filter(i => i.json.isPortuguese);\n  const titles = ptItems.slice(0, 15).map((i,n) => (n+1) + '. ' + i.json.title).join('\\n');\n  return JSON.stringify({\n    model: 'claude-haiku-4-5-20251001',\n    max_tokens: 800,\n    messages: [{\n      role: 'user',\n      content: 'Translate these Portuguese news headlines to natural English. Return ONLY a numbered list with the same numbers, one translation per line, nothing else.\\n\\n' + titles\n    }]\n  });\n})() }}"
            }
          ]
        },
        "options": {}
      },
      "name": "Translate PT titles (batch)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        920,
        860
      ]
    },
    {
      "parameters": {
        "functionCode": "// Parse translated titles and merge back with original PT items\nconst response = JSON.parse($input.first().json.body);\nconst text = response.content[0].text;\nconst lines = text.trim().split('\\n').filter(l => l.trim());\nconst translations = {};\nfor (const line of lines) {\n  const match = line.match(/^(\\d+)\\.\\s*(.+)$/);\n  if (match) translations[parseInt(match[1])] = match[2].trim();\n}\n\n// Get the PT items from previous context via workflow static data\n// We pass them through via the input items\nconst ptItems = $('Mark as Portuguese').all();\nreturn ptItems.slice(0,15).map((item, idx) => ({\n  json: {\n    ...item.json,\n    translatedTitle: translations[idx+1] || item.json.title\n  }\n}));"
      },
      "name": "Apply translations",
      "type": "n8n-nodes-base.code",
      "position": [
        1140,
        860
      ]
    },
