              "fieldValue": "={{ $json.region }}"
            },
            {
              "fieldId": "published_at",
              "fieldValue": "={{ $json.published_at }}"
            },
            {
              "fieldId": "status",
              "fieldValue": "approved"
            }
          ]
        },
        "filterByFormFields": {
          "values": [
            {
              "fieldId": "source_url",
              "fieldValue": "={{ $json.source_url }}"
            }
          ]
        }
      },
